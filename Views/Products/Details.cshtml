@model IBMS.Models.Product
@{
    ViewData["Title"] = "Product Details";
}

<h2>Product Details</h2>

<div class="card shadow-sm col-md-6">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.ProductName</dd>

            <dt class="col-sm-4">Category</dt>
            <dd class="col-sm-8">@Model.Category</dd>

            <dt class="col-sm-4">Price</dt>
            <dd class="col-sm-8">@Model.UnitPrice</dd>

            <dt class="col-sm-4">Quantity</dt>
            <dd class="col-sm-8">@Model.Quantity</dd>

            <dt class="col-sm-4">Tax Rate</dt>
            <dd class="col-sm-8">@Model.TaxRate</dd>
        </dl>

        <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
    </div>
</div>
