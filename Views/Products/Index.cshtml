@model IEnumerable<IBMS.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<h2 class="mb-3">Products</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Create" class="btn btn-dark">Add Product</a>
    <input type="text"id="tableSearch"class="form-control w-25"placeholder="Search products..." />
</div>

<table class="table table-bordered table-striped align-middle" id="dataTable">
    <thead class="table-dark">
        <tr>
            <th role="button" onclick="sortTable(0)">Name ⬍</th>
            <th role="button" onclick="sortTable(1)">Category ⬍</th>
            <th role="button" onclick="sortTable(2)">Price ⬍</th>
            <th role="button" onclick="sortTable(3)">Quantity ⬍</th>
            <th role="button" onclick="sortTable(4)">Tax ⬍</th>
            <th style="width:180px">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Category</td>
                <td>@item.UnitPrice.ToString("N2", new System.Globalization.CultureInfo("en-IN"))</td>
                <td>@item.Quantity.ToString("N0", new System.Globalization.CultureInfo("en-IN"))</td>
                <td>@item.TaxRate</td>
                <td class="text-nowrap">
                    <div class="d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-warning">Edit</a>
                        <button type="button"class="btn btn-sm btn-danger"data-bs-toggle="modal"
                                data-bs-target="#globalDeleteModal"data-id="@item.ProductId"
                                data-name="@item.ProductName"data-action="@Url.Action("DeleteConfirmed", "Products")">Delete
                        </button>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<partial name="_DeleteModal" />

@section Scripts {
    <script src="~/js/global-search.js"></script>
    <script src="~/js/global-sort.js"></script>
}
