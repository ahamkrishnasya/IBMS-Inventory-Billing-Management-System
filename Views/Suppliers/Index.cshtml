@model IEnumerable<IBMS.Models.Supplier>

@{
    ViewData["Title"] = "Suppliers";
}

<h2 class="mb-3">Suppliers</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <a class="btn btn-dark" asp-action="Create">Add New</a>
    <input type="text"id="tableSearch"class="form-control w-25"placeholder="Search suppliers..." />
</div>

<table class="table table-bordered table-striped align-middle" id="dataTable">
    <thead class="table-dark">
        <tr>
            <th role="button" onclick="sortTable(0)">Supplier Name ⬍</th>
            <th role="button" onclick="sortTable(1)">Contact Number ⬍</th>
            <th role="button" onclick="sortTable(2)">Email ⬍</th>
            <th role="button" onclick="sortTable(3)">Address ⬍</th>
            <th style="width:220px">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.SupplierName</td>
                <td>@item.ContactNumber</td>
                <td>@item.Email</td>
                <td>@item.Address</td>
                <td class="text-nowrap">
                    <div class="d-flex gap-2">
                        <a asp-action="Details"asp-route-id="@item.SupplierId"class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit"asp-route-id="@item.SupplierId"class="btn btn-sm btn-warning">Edit</a>
                        <button class="btn btn-sm btn-danger"data-bs-toggle="modal"data-bs-target="#globalDeleteModal"
                                data-id="@item.SupplierId"data-name="@item.SupplierName"
                                data-action="@Url.Action("DeleteConfirmed", "Suppliers")">Delete
                        </button>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<partial name="_DeleteModal" />

@section Scripts {
    <script src="~/js/global-search.js"></script>
    <script src="~/js/global-sort.js"></script>
}
