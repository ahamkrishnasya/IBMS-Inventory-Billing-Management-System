@model IBMS.Models.Supplier

@{
    ViewData["Title"] = "Supplier Details";
}

<h2 class="mb-3">Supplier Details</h2>

<div class="card shadow-sm col-md-6">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Supplier Name</dt>
            <dd class="col-sm-8">@Model.SupplierName</dd>

            <dt class="col-sm-4">Contact Number</dt>
            <dd class="col-sm-8">@Model.ContactNumber</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Address</dt>
            <dd class="col-sm-8">@Model.Address</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit"
       asp-route-id="@Model.SupplierId"
       class="btn btn-warning">
        Edit
    </a>

    <a asp-action="Index"
       class="btn btn-secondary ms-2">
        Back
    </a>
</div>
