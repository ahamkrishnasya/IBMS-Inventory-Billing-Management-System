@model IBMS.Models.Sale

@{
    ViewData["Title"] = "Sale Details";
}

<h2>Sale Details</h2>

<div class="card shadow-sm col-md-6">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Sale Date</dt>
            <dd class="col-sm-9">@Model.SaleDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Customer</dt>
            <dd class="col-sm-9">@Model.Customer.CustomerName</dd>

            <dt class="col-sm-3">Product</dt>
            <dd class="col-sm-9">@Model.Product.ProductName</dd>

            <dt class="col-sm-3">Quantity</dt>
            <dd class="col-sm-9">@Model.Quantity</dd>

            <dt class="col-sm-3">Total Amount</dt>
            <dd class="col-sm-9">@Model.TotalAmount</dd>

            <dt class="col-sm-3">Tax Amount</dt>
            <dd class="col-sm-9">@Model.TaxAmount</dd>

            <dt class="col-sm-3">Net Amount</dt>
            <dd class="col-sm-9">@Model.NetAmount</dd>
        </dl>
        <a asp-action="Edit" asp-route-id="@Model.SaleId" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
    </div>
</div>