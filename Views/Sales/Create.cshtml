@model IBMS.Models.DTOs.SaleDto
@using System.Text.Json

<h2 class="mb-3">Create Sale</h2>

<form asp-action="Create" method="post" class="col-md-6">

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <!-- CUSTOMER -->
    <div class="mb-3">
        <label class="form-label">Customer</label>
        <select asp-for="CustomerId"
                asp-items="Model.CustomerList"
                class="form-select">
            <option value="">-- Select Customer --</option>
        </select>
    </div>

    <!-- PRODUCT -->
    <div class="mb-3">
        <label class="form-label">Product</label>
        <select asp-for="ProductId"
                asp-items="Model.ProductList"
                class="form-select"
                id="ProductId">
            <option value="">-- Select Product --</option>
        </select>
    </div>

    <!-- QUANTITY -->
    <div class="mb-3">
        <label class="form-label">Quantity</label>
        <input asp-for="Quantity"
               type="number"
               min="1"
               class="form-control"
               id="Quantity" />
    </div>

    <!-- DISPLAY ONLY (NOT POSTED) -->
    <div class="mb-3">
        <label class="form-label">Total Amount</label>
        <input class="form-control" readonly id="TotalAmount" />
    </div>

    <div class="mb-3">
        <label class="form-label">Tax Amount</label>
        <input class="form-control" readonly id="TaxAmount" />
    </div>

    <div class="mb-3">
        <label class="form-label">Net Amount</label>
        <input class="form-control" readonly id="NetAmount" />
    </div>

    <button type="submit" class="btn btn-dark">Save</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const prices = @Html.Raw(JsonSerializer.Serialize(Model.ProductPrices));
        const taxes = @Html.Raw(JsonSerializer.Serialize(Model.ProductTaxRates));

        const product = document.getElementById("ProductId");
        const qty = document.getElementById("Quantity");

        function calculate() {
            if (!product.value || !qty.value) return;

            const price = prices[product.value] || 0;
            const taxRate = taxes[product.value] || 0;

            const total = price * qty.value;
            const tax = (total * taxRate) / 100;

            document.getElementById("TotalAmount").value = total.toFixed(2);
            document.getElementById("TaxAmount").value = tax.toFixed(2);
            document.getElementById("NetAmount").value = (total + tax).toFixed(2);
        }

        product.addEventListener("change", calculate);
        qty.addEventListener("input", calculate);
    </script>
}
