@model IBMS.Models.DTOs.PurchaseDto
@using System.Text.Json

<h2>Create Purchase</h2>

<form method="post" class="col-md-6">

    <div class="mb-3">
        <label>Supplier</label>
        <select asp-for="SupplierId"asp-items="Model.SupplierList"class="form-select">
            <option value="">-- Select Supplier --</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Product</label>
        <select asp-for="ProductId"asp-items="Model.ProductList"class="form-select"id="ProductId">
            <option value="">-- Select Product --</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Rate</label>
        <input id="Rate" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label>Quantity</label>
        <input asp-for="Quantity" class="form-control" id="Quantity" />
    </div>

    <div class="mb-3">
        <label>Total</label>
        <input asp-for="TotalAmount"class="form-control"id="TotalAmount"readonly />
    </div>

    <button type="submit" class="btn btn-dark">Save</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
</form>

@section Scripts {
    <script>
        const productPrices = @Html.Raw(JsonSerializer.Serialize(Model.ProductPrices ?? new Dictionary<int, decimal>()));

        const productSelect = document.getElementById("ProductId");
        const quantityInput = document.getElementById("Quantity");
        const rateInput = document.getElementById("Rate");
        const totalInput = document.getElementById("TotalAmount");

        function calculate() {
            const productId = productSelect.value;
            const rate = productPrices[productId] || 0;
            const qty = parseFloat(quantityInput.value || 0);

            rateInput.value = rate.toFixed(2);
            totalInput.value = (rate * qty).toFixed(2);
        }

        productSelect.addEventListener("change", calculate);
        quantityInput.addEventListener("input", calculate);
        calculate();
    </script>
}
