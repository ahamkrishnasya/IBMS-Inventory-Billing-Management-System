@model IBMS.Models.Purchase

@{
    ViewData["Title"] = "Purchase Details";
}

<h2 class="mb-3">Purchase Details</h2>

<div class="card shadow-sm col-md-6">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Quantity</dt>
            <dd class="col-sm-8">@Model.Quantity</dd>

            <dt class="col-sm-4">Purchase Date</dt>
            <dd class="col-sm-8">@Model.PurchaseDate.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-4">Total Amount</dt>
            <dd class="col-sm-8">@Model.TotalAmount</dd>

            <dt class="col-sm-4">Supplier</dt>
            <dd class="col-sm-8">@Model.Supplier.SupplierName</dd>

            <dt class="col-sm-4">Product</dt>
            <dd class="col-sm-8">@Model.Product.ProductName</dd>
        </dl>

        <a asp-action="Edit"asp-route-id="@Model.PurchaseId"class="btn btn-warning">Edit</a>
        <a asp-action="Index"class="btn btn-secondary ms-2">Back</a>
    </div>
</div>
