@model IEnumerable<IBMS.Models.Purchase>

@{
    ViewData["Title"] = "Purchases";
}

<h2 class="mb-3">Purchases</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Create" class="btn btn-dark">
        Add Purchase
    </a>

    <input type="text"
           id="tableSearch"
           class="form-control w-25"
           placeholder="Search purchases..." />
</div>

<table class="table table-bordered table-striped align-middle" id="dataTable">
    <thead class="table-dark">
        <tr>
            <th role="button" onclick="sortTable(0)">Quantity ⬍</th>
            <th role="button" onclick="sortTable(1)">Date ⬍</th>
            <th role="button" onclick="sortTable(2)">Amount ⬍</th>
            <th role="button" onclick="sortTable(3)">Supplier ⬍</th>
            <th role="button" onclick="sortTable(4)">Product ⬍</th>
            <th style="width:180px">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Quantity</td>
                <td>@item.PurchaseDate.ToString("dd/MM/yyyy")</td>
                <td>@item.TotalAmount</td>
                <td>@item.Supplier.SupplierName</td>
                <td>@item.Product.ProductName</td>
                <td class="text-nowrap">
                    <div class="d-flex gap-2">
                        <a asp-action="Details"
                           asp-route-id="@item.PurchaseId"
                           class="btn btn-sm btn-info">
                            Details
                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@item.PurchaseId"
                           class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <button class="btn btn-sm btn-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#globalDeleteModal"
                                data-id="@item.PurchaseId"
                                data-name="@item.Product.ProductName"
                                data-action="@Url.Action("DeleteConfirmed", "Purchases")">
                            Delete
                        </button>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<partial name="_DeleteModal" />

@section Scripts {
    <script src="~/js/global-search.js"></script>
    <script src="~/js/global-sort.js"></script>
}
