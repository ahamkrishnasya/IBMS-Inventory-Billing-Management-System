@model IEnumerable<IBMS.Models.Customer>

@{
    ViewData["Title"] = "Customers";
}

<h2 class="mb-3">Customers</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Create" class="btn btn-dark">
        Add Customer
    </a>

    <input type="text"
           id="tableSearch"
           class="form-control w-25"
           placeholder="Search customers..." />
</div>

<table class="table table-bordered table-striped align-middle" id="dataTable">
    <thead class="table-dark">
        <tr>
            <th role="button" onclick="sortTable(0)">Name ⬍</th>
            <th role="button" onclick="sortTable(1)">Contact ⬍</th>
            <th role="button" onclick="sortTable(2)">Email ⬍</th>
            <th role="button" onclick="sortTable(3)">Address ⬍</th>
            <th style="width:180px">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CustomerName</td>
                <td>@item.ContactNumber</td>
                <td>@item.Email</td>
                <td>@item.Address</td>
                <td class="text-nowrap">
                    <div class="d-flex gap-2">
                        <a asp-action="Details"
                           asp-route-id="@item.CustomerId"
                           class="btn btn-sm btn-info">
                            Details
                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@item.CustomerId"
                           class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <button class="btn btn-sm btn-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#globalDeleteModal"
                                data-id="@item.CustomerId"
                                data-name="@item.CustomerName"
                                data-action="@Url.Action("DeleteConfirmed", "Customers")">
                            Delete
                        </button>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<partial name="_DeleteModal" />

@section Scripts {
    <script src="~/js/global-search.js"></script>
    <script src="~/js/global-sort.js"></script>
}
